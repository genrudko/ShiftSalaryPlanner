<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetCellRoot"
    android:layout_width="match_parent"
    android:layout_height="58dp"
    android:padding="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widgetDayNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F3F6FF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetTodayDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="•"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/widgetShiftCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="#3E528E"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="3dp"
            android:paddingTop="3dp"
            android:paddingEnd="3dp"
            android:paddingBottom="3dp"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetShiftTitle"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widgetShiftSubtitle"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </LinearLayout>
</FrameLayout>
