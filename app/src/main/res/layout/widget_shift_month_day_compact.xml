<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetCellRoot"
    android:layout_width="match_parent"
    android:layout_height="58dp"
    android:background="@drawable/widget_cell_bg"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widgetDayNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F3F6FF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widgetTodayDot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="•"
                android:textColor="#FFFFFF"
                android:textSize="7sp"
                android:visibility="gone" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/widgetShiftChipWrap"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="3dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/widgetShiftChipBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/widget_shift_chip_bg"
                android:scaleType="fitXY" />

            <TextView
                android:id="@+id/widgetShiftCard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:id="@+id/widgetShiftTitle"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/widgetShiftSubtitle"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </LinearLayout>
</FrameLayout>
