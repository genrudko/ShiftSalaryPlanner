<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widgetCellRoot"
    android:layout_width="match_parent"
    android:layout_height="92dp"
    android:background="@drawable/widget_cell_bg"
    android:orientation="vertical"
    android:padding="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widgetDayNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F3F6FF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetTodayDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:text="@string/widget_today_dot"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:visibility="gone"
            tools:ignore="SmallSp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/widgetShiftTitleWrap"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/widgetShiftTitleBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:scaleType="fitXY"
            android:src="@drawable/widget_shift_chip_bg" />

        <TextView
            android:id="@+id/widgetShiftTitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/widgetShiftSubtitleWrap"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_marginTop="2dp">

        <ImageView
            android:id="@+id/widgetShiftSubtitleBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:scaleType="fitXY"
            android:src="@drawable/widget_shift_meta_bg" />

        <TextView
            android:id="@+id/widgetShiftSubtitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            tools:ignore="SmallSp" />
    </FrameLayout>
</LinearLayout>
